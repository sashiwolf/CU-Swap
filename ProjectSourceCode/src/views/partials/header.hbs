<head>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<header class="py-3" style="background:black;">
  <div class="container-fluid d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center">
      <img src="/images/image.png" alt="CU Swap Logo" height="165px">
      {{#if isModerator}}
        <span class="text-light fw-bold ms-3">Welcome Admin</span>
      {{/if}}
    </div>
    {{#if showAuthButtons}}
      <nav class="d-flex gap-3">
      <a href="/login" class="btn btn-outline-light rounded-pill fw-bold px-4 py-2">Login</a>
      <a href="/register" class="btn btn-outline-light rounded-pill fw-bold px-4 py-2">Register</a>
    </nav>
  </div>
    {{/if}}
</header>
