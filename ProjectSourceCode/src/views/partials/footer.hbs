<style>
/* Make the page a flex column so the footer can push to the bottom */
  html, body {
    height: 100%;
  }
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  main {
    flex: 1;                /* grow to push footer down */
    display: flex;
    flex-direction: column;
  }

.cu-footer {
  background: #000;
  color: #fff;
  text-align: center;
  padding: 1.25rem 0;      /* 20px-ish */
  position: relative;
  font-size: 1.05rem;
  margin-top: auto;         /* stick to bottom when page is short */
}

/* Gold bar at top */
.cu-footer::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 5px;
  background: #d4af37;     /* CU gold */
}

.cu-footer__inner {
  margin: 0 auto;
  width: 100%;
  max-width: 1400px;
}
</style>
<footer class="cu-footer">
  <div class="cu-footer__inner">
    © CU Swap — Built by CU Boulder Students
  </div>
</footer>
<!-- Bootstrap JS -->
<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
  crossorigin="anonymous">
</script>

<!-- Including the script.js file (using defer so that the HTML loads before the js) -->
<script src="/js/script.js" defer></script>
