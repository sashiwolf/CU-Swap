{{!< main }}

<main>
  <div class="container py-4">
    <h2 class="mb-4">Registered Users</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
      {{#each users}}
        <div class="col d-flex justify-content-center">
          <div class="p-4 bg-light rounded-pill shadow-sm w-100" style="max-width: 360px;">
            <div class="text-center fw-bold fs-5 mb-2">
              {{this.username}}
            </div>

            <div class="d-flex justify-content-center align-items-center gap-2">
              <span>{{this.email}}</span>
              <span>|</span>
              <span>{{this.phone_num}}</span>
            </div>

            <div class="mt-3 text-center">
              <button
                type="button"
                class="btn btn-danger btn-sm"
                data-bs-toggle="modal"
                data-bs-target="#removeUserModal-{{this.user_id}}">
                Remove User
              </button>
            </div>
          </div>
        </div>

        <!-- Confirm remove modal -->
        <div class="modal fade" id="removeUserModal-{{this.user_id}}" tabindex="-1"
             aria-labelledby="removeUserLabel-{{this.user_id}}" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <form action="/users/{{this.user_id}}/remove" method="POST">
                <div class="modal-header">
                  <h5 class="modal-title" id="removeUserLabel-{{this.user_id}}">
                    Remove user "{{this.username}}"?
                  </h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                  <p>Are you sure you want to remove this user?</p>
                  <p class="mb-0"><strong>Email:</strong> {{this.email}}</p>
                  <p class="mb-0"><strong>Phone:</strong> {{this.phone_num}}</p>
                  <p class="mt-2 text-danger small">
                    This will delete their reviews and listings, add them to the banned list,
                    and remove their account.
                  </p>
                </div>

                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button type="submit" class="btn btn-danger">Yes, remove user</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
