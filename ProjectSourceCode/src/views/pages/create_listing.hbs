<style>
  /* Outer wrapper – centers card and gives breathing room */
.listing-form-wrapper {
  /* no need for full-viewport centering */
  min-height: auto;
  display: flex;
  justify-content: center;   /* center horizontally */
  align-items: flex-start;   /* start below the top */
  padding: 4rem 1rem 3rem;   /* top padding pushes card down */
  background: #f5f5f5;
}

/* The actual card/box */
.listing-card {
  width: 100%;
  max-width: 520px;
  background: #ffffff;
  border-radius: 18px;
  padding: 28px 30px;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.16);
  border-top: 3px solid #d9b23d; /* gold accent line */
}

/* Space out fields nicely inside the card */
.listing-card form > * {
  display: block;
  width: 100%;
  margin-bottom: 14px;
}

/* Labels */
.listing-card label {
  margin-bottom: 4px;
  font-size: 0.9rem;
  font-weight: 600;
}

/* Inputs + select */
.listing-card input[type="text"],
.listing-card input[type="number"],
.listing-card select {
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  border: 1px solid #d0d0d0;
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

.listing-card input[type="text"]:focus,
.listing-card input[type="number"]:focus,
.listing-card select:focus {
  border-color: #d9b23d;
  box-shadow: 0 0 0 0.12rem rgba(217, 178, 61, 0.35);
}

/* Submit button */
.listing-card button[type="submit"] {
  width: 100%;
  margin-top: 6px;
  padding: 0.55rem 1.2rem;
  border-radius: 999px;
  border: none;
  background-color: #000;  /* black */
  color: #fff;
  font-weight: 500;
  cursor: pointer;
  transition: background-color 0.15s ease, color 0.15s ease;
}

.listing-card button[type="submit"]:hover,
.listing-card button[type="submit"]:focus {
  background-color: #cfb87c; /* gold on hover */
  color: #000;
}

</style>

<div class="listing-form-wrapper">
  <div class="listing-card">

    <form action="/create_listing" method="POST">
      <input type="text" name="title" placeholder="Title">
      <input type="text" name="description" placeholder="Description">
      <input type="number" step="0.01" name="price" placeholder="Price">
      <label for="category"></label>
      <select id="category" name="category" required>
        <option value="">Select a category</option>
        {{#each categories}}
          <option value="{{this.category}}">{{this.category}}</option>
        {{/each}}
      </select>
      <input type="text" name="image_url" placeholder="Image URL">
      <button type="submit">Submit</button>
    </form>
  </div>
</div>
