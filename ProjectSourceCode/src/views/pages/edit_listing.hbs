{{!< main }}
<style>
  .listing-form-wrapper {
    display: flex;
    justify-content: center;
    margin: 40px auto;
  }

  .listing-card {
    width: 100%;
    max-width: 520px;
    background: #ffffff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
    border: 1px solid #e5e7eb;
  }
</style>

<div class="listing-form-wrapper">
  <div class="listing-card">
    <h1 class="h4 mb-3">Edit Listing</h1>
    <p class="text-muted mb-4">Update the details of your listing and save the changes when you’re ready.</p>

    {{#if error}}
      <div class="alert alert-danger">{{error}}</div>
    {{/if}}

    <form action="/listings/{{listing.listing_id}}/edit" method="POST" class="d-flex flex-column gap-3">
      <div>
        <label for="title" class="form-label">Title</label>
        <input
          id="title"
          type="text"
          name="title"
          class="form-control"
          value="{{listing.title}}"
          required>
      </div>

      <div>
        <label for="description" class="form-label">Description</label>
        <textarea
          id="description"
          name="description"
          class="form-control"
          rows="4"
          placeholder="Describe your item">{{listing.description}}</textarea>
      </div>

      <div>
        <label for="price" class="form-label">Price (USD)</label>
        <input
          id="price"
          type="number"
          step="0.01"
          name="price"
          class="form-control"
          value="{{listing.price}}">
      </div>

      <div>
        <label for="category" class="form-label">Category</label>
        <select id="category" name="category" class="form-select" required>
          <option value="">Select a category</option>
          {{#each categories}}
            <option
              value="{{this.category}}"
              {{#if (eq this.category ../listing.category)}}selected{{/if}}>
              {{this.category}}
            </option>
          {{/each}}
        </select>
      </div>

      <div>
        <label for="image_url" class="form-label">Image URL</label>
        <input
          id="image_url"
          type="url"
          name="image_url"
          class="form-control"
          value="{{listing.image_url}}">
      </div>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <a href="/my-listings" class="btn btn-link">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>
