{{!< main }}
<div class="container mt-5">
  <h1 class="text-center mb-4">My Reviews</h1>

  <div id="flash" class="mb-3"></div>

  {{#if reviews.length}}
    <div class="row" id="reviews-grid">
      {{#each reviews}}
        <div class="col-md-4 mb-4" id="review-card-col-{{this.review_id}}">
          <div class="card shadow-sm h-100" id="review-card-{{this.review_id}}">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title text-primary">{{this.reviewee_username}}</h5>

              {{#if this.rating}}
                <p class="mb-1"><span class="text-warning">★</span> {{this.rating}} / 5</p>
              {{/if}}

              <p class="card-text flex-grow-1">{{this.content}}</p>

              <div class="mt-2 ms-auto">
                <!-- Trigger modal -->
                <button
                  class="btn btn-outline-danger"
                  data-bs-toggle="modal"
                  data-bs-target="#confirmDeleteModal"
                  data-review-id="{{this.review_id}}">
                  Delete review
                </button>
              </div>

            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}

  <div
    id="no-reviews-message"
    class="text-center mt-5 {{#if reviews.length}}d-none{{/if}}">
    <p class="text-muted fs-5 mb-0">You haven’t written any reviews yet.</p>
  </div>
</div>

<!-- One shared Bootstrap modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete this review?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        This action cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
      </div>
    </div>
  </div>
</div>
