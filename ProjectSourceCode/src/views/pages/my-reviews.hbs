{{!< main }}

<div class="container mt-5">
  <h1 class="text-center mb-4">My Reviews</h1>

  {{#if reviews.length}}
    <div class="row">
      {{#each reviews}}
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title text-primary">Review #{{this.review_id}}</h5>
              <p class="card-text flex-grow-1">{{this.content}}</p>

              {{#if this.rating}}
                <p class="card-text">
                  <span class="text-warning">★</span> {{this.rating}} / 5
                </p>
              {{/if}}

              <button class="btn btn-danger mt-auto" onclick="deleteReview('{{this.review_id}}')">
                Delete Review
              </button>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="text-center mt-5">
      <p class="text-muted fs-5">You haven’t written any reviews yet.</p>
    </div>
  {{/if}}
</div>

<script>
  async function deleteReview(id) {
    if (confirm('Are you sure you want to delete this review?')) {
      const response = await fetch(`/delete-review/${id}`, {
        method: 'DELETE'
      });
      const data = await response.json();
      if (response.ok) {
        alert(data.message);
        window.location.reload();
      } else {
        alert(data.error || 'Failed to delete review.');
      }
    }
  }
</script>
