{{!< main }} <div class="container mt-5">
  <h1 class="text-center mb-4">My Reviews</h1>

  <div id="flash" class="mb-3"></div>

  {{#if reviews.length}}
  <div class="row" id="reviews-grid">
    {{#each reviews}}
    <div class="col-md-4 mb-4" id="review-card-col-{{this.review_id}}">
      <div class="card shadow-sm h-100" id="review-card-{{this.review_id}}">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title text-primary">{{this.reviewee_username}}</h5>

          {{#if this.rating}}
          <p class="mb-1"><span class="text-warning">★</span> {{this.rating}} / 5</p>
          {{/if}}

          <p class="card-text flex-grow-1">{{this.content}}</p>

          <div class="mt-2 ms-auto">
            <div class="dropdown">
              <button class="btn btn-outline-danger dropdown-toggle" type="button" id="dropdown-{{this.review_id}}"
                data-bs-toggle="dropdown" aria-expanded="false">
                Delete review
              </button>

              <div class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="dropdown-{{this.review_id}}">
                <h6 class="dropdown-header px-0">Delete this review?</h6>
                <p class="small mb-2 px-0">This action cannot be undone.</p>
                <div class="d-flex gap-2 justify-content-end">
                  <button type="button" class="btn btn-outline-secondary btn-sm" data-cancel>Cancel</button>
                  <button type="button" class="btn btn-danger btn-sm" data-confirm
                    data-id="{{this.review_id}}">Delete</button>
                </div>
              </div>
            </div>
          </div>

        </div> 
      </div> 
    </div> 
    {{/each}}
  </div>
  {{else}}
  <div class="text-center mt-5">
    <p class="text-muted fs-5">You haven’t written any reviews yet.</p>
  </div>
  {{/if}}
  </div>