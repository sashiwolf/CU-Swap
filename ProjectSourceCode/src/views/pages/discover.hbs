{{!< main }}

<style>
  .create-listing-black {
  background-color: #000 !important; /* black */
  color: #fff !important;            /* white text */
  border: none;
}

/* hover + focus */
.create-listing-black:hover,
.create-listing-black:focus {
  background-color: #cfb87c !important; /* gold */
  color: #000 !important;               /* black text */
}

</style>

<main>
  <div class="container py-4">
    <!-- Filter + Create Listing bar -->
    <div class="d-flex flex-wrap align-items-center gap-3 mb-4 p-3 bg-light rounded">
      <form method="GET" action="/discover" class="d-flex align-items-center gap-2 flex-wrap mb-0">
        <label for="category" class="form-label fw-semibold mb-0">Category</label>
        <select name="category" id="category" class="form-select form-select-sm" onchange="this.form.submit()">
          <option value="">All Categories</option>
          {{#each categories}}
            <option value="{{this.category}}" {{#if (eq this.category ../selectedCategory)}}selected{{/if}}>
              {{this.category}}
            </option>
          {{/each}}
        </select>
      </form>

      <a href="/create_listing" class="btn btn-primary btn-sm ms-auto create-listing-black">
        Create Listing
      </a>
    </div>
    <!-- Optional notice -->
    {{#if notice}}
      <div class="alert alert-warning">
        {{notice}}
      </div>
    {{/if}}

    <!-- Listings grid -->
    <div class="row row-cols-1 row-cols-md-3 g-4">
      {{#each listings}}
        <div class="col">
          <!-- Card itself -->
          <div class="card h-100 shadow-sm">
            <img
              src="{{this.image_url}}"
              class="card-img-top"
              alt="{{this.title}} thumbnail"
              style="height:200px; object-fit:cover;"
            >

            <div class="card-body d-flex flex-column">
              <h5 class="card-title text-primary mb-2">
                <a href="/listings/{{this.listing_id}}" class="text-decoration-none text-primary">
                  {{this.title}}
                </a>
              </h5>

              <h4 class="card-subtitle text-success mt-auto">
                <strong>${{this.price}}</strong>
              </h4>

              <!-- Make whole card clickable without touching the delete button -->
              <a
                href="/listings/{{this.listing_id}}"
                class="stretched-link"
                aria-label="View {{this.title}}"
              ></a>
            </div>

            {{#if ../isModerator}}
                <div class="card-footer bg-white border-0">
                <button
                    type="button"
                    class="btn btn-danger btn-sm w-100"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteModal-{{this.listing_id}}"
                    style="position: relative; z-index: 2;"
                    onclick="event.stopPropagation();">Delete</button>
                </div>
            {{/if}}
          </div>
          <!-- Modal for delete reason (stays where it was) -->
          {{#if ../isModerator}}
            <div class="modal fade" id="deleteModal-{{this.listing_id}}" tabindex="-1"
                 aria-labelledby="deleteModalLabel-{{this.listing_id}}" aria-hidden="true">
              <div class="modal-dialog">
                <div class="modal-content">
                  <form action="/listings/{{this.listing_id}}/admin_delete" method="POST">
                    <div class="modal-header">
                      <h5 class="modal-title" id="deleteModalLabel-{{this.listing_id}}">
                        Delete listing: "{{this.title}}"
                      </h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                      <p>Why are you removing this listing?</p>
                      <textarea class="form-control" name="reason" rows="3" required></textarea>
                    </div>

                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                      <button type="submit" class="btn btn-danger">Delete listing</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
