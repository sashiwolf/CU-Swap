<!--To do: main grid-->
<main>
    <div class="container py-4">
        <div class="row row-cols-1 row-cols-md-3 g-4">

            {{#each listings}}

            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="{{this.image_url}}" class="card-img-top" alt="{{this.title}} thumbnail"
                        style="height: 200px; object-fit: cover;">

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary">{{this.title}}</h5>

                        <h4 class="card-subtitle mb-2 text-success mt-auto">
                            <strong>${{this.price}}</strong>
                        </h4>

                         {{#if ../isModerator}}
                            <form action="/listings/{{this.id}}/delete" method="POST" class="mt-2">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    {{/if}}
                    </div>
                </div>
            </div>
            {{/each}}

        </div>
    </div>
</main>